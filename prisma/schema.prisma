generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum WorkspaceRole {
  DIRECTOR
  ACCOUNTANT
  EMPLOYEE
}

enum PersonType {
  DIRECTOR
  ACCOUNTANT
  EMPLOYEE
  CONTRACTOR
  CLIENT_CONTACT
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum GstTreatment {
  GST_INCLUDED
  GST_FREE
  NO_GST_OVERSEAS
  MANUAL_OVERRIDE
}

enum BasTreatment {
  GST_COLLECTED
  GST_PAID
  PAYROLL
  NONE
}

enum BasFrequency {
  QUARTERLY
  MONTHLY
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model Workspace {
  id                      String        @id @default(cuid())
  name                    String
  legalName               String?
  abn                     String?
  address                 String?
  contactEmail            String?
  gstRegistered           Boolean?
  basFrequency            BasFrequency?
  financialYearStartMonth Int?
  invoicePrefix           String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  bankAccounts BankAccount[]
  categories   Category[]
  people       Person[]
  expenses     Expense[]
  clients      Client[]
  invoices     Invoice[]
}

model BankAccount {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  bank        String
  label       String
  ownerLabel  String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  expenses    Expense[]

  @@index([workspaceId])
}

model Category {
  id                  String       @id @default(cuid())
  workspaceId         String
  name                String
  type                CategoryType
  defaultGstTreatment GstTreatment
  basTreatment        BasTreatment
  active              Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  workspace           Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  expenses            Expense[]

  @@index([workspaceId])
}

model Person {
  id             String        @id @default(cuid())
  workspaceId    String
  name           String
  email          String?
  personType     PersonType
  workspaceRole  WorkspaceRole
  payrollEnabled Boolean       @default(false)
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invoices       Invoice[]

  @@unique([id, workspaceId])
  @@index([workspaceId])
}

model Client {
  id             String   @id @default(cuid())
  workspaceId    String
  name           String
  email          String?
  abn            String?
  billingAddress String?
  notes          String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invoices  Invoice[]

  @@unique([id, workspaceId])
  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Invoice {
  id                  String        @id @default(cuid())
  workspaceId         String
  clientId            String
  personId            String?
  invoiceNumber       String
  issueDate           DateTime
  dueDate             DateTime?
  status              InvoiceStatus @default(DRAFT)
  grossCents          Int
  gstTreatment        GstTreatment
  userEnteredGstCents Int?
  paymentDate         DateTime?
  evidenceUrl         String?
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client    @relation(fields: [clientId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  person    Person?   @relation(fields: [personId, workspaceId], references: [id, workspaceId], onDelete: Restrict)

  @@unique([workspaceId, invoiceNumber])
  @@index([workspaceId])
  @@index([clientId])
  @@index([personId])
  @@index([issueDate])
}

model Expense {
  id                  String       @id @default(cuid())
  workspaceId         String
  date                DateTime
  supplier            String?
  categoryId          String
  bankAccountId       String
  grossCents          Int
  gstTreatment        GstTreatment
  userEnteredGstCents Int?
  receiptUrl          String?
  notes               String?
  overrideReason      String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)

  @@index([workspaceId])
  @@index([categoryId])
  @@index([bankAccountId])
  @@index([date])
}
